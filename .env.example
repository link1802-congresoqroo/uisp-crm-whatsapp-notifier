# ==========================================
# SERVIDOR
# ==========================================
PORT=3000
IP=localhost
NODE_ENV=production
APP_URL=http://localhost:3000
# ==========================================
# SEGURIDAD DE WEBHOOKS
# ==========================================
# Secreto compartido para autenticar webhooks entrantes.
# Generar con: openssl rand -hex 32
# Debe agregarse como ?token=VALOR en la URL del webhook en UISP y en el plugin.
WEBHOOK_SECRET=
# Verificar eventos contra GET /webhook-events/{uuid} de UISP:
#   off     - no verificar
#   log     - verificar y solo advertir en logs (default, recomendado con el plugin activo)
#   enforce - rechazar eventos que UISP no reconozca (rompe el plugin de facturas recurrentes)
WEBHOOK_VERIFY_EVENTS=log

# ==========================================
# UISP Configuration
# ==========================================
UISP_URL=https://localhost.com.mx
UISP_API_KEY=
# El prefijo de la API del CRM está congelado en v1.0 aunque la app UISP sea 3.0.x
UISP_BASE_URL=https://localhost.com.mx/crm/api/v1.0

# ==========================================
# WhatsApp Configuration
# ==========================================
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_LANGUAGE_CODE=
UISP_MESSAGING_TEMPLATE_NAME=
UISP_MESSAGING_TEMPLATE_LANGUAGE=

# ==========================================
# ALERTAS OPERATIVAS (opcional)
# ==========================================
# Teléfono del administrador (formato internacional sin +, ej. 5219981234567).
# Recibe por WhatsApp las alertas de POST /webhook/alert (ej. plugin con errores).
# Requiere UISP_MESSAGING_TEMPLATE_NAME configurado. Vacío = alertas solo en logs.
ADMIN_PHONE=
